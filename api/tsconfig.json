{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "es2020",
    "module": "commonjs",
    "rootDir": "./src",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "removeComments": false,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "exclude": ["./dist/**"]
}
