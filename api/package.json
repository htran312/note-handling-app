{
  "name": "api",
  "version": "0.1.0",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "knex": "^3.1.0",
    "kysely": "^0.27.6",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/knex": "^0.0.37",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.10.9",
    "@types/swagger-ui-express": "^4.1.8",
    "kysely-codegen": "^0.14.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc --project tsconfig.build.json -p tsconfig.build.json",
    "gen:db": "DATABASE_URL=postgresql://api_user:password@localhost:5432/api_dev kysely-codegen --dialect postgres --out-file src/schema.ts && prettier --write src/schema.ts",
    "migrate:latest": "knex --knexfile ./knexfile.ts migrate:latest",
    "migrate:make": "knex --knexfile ./knexfile.ts migrate:make"
  }
}
